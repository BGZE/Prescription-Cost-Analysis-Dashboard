# Copy to .env and fill in. .env is git-ignored.

# --- Database ---------------------------------------------------------------
# Local dev (docker-compose or a local Postgres):
DATABASE_URL=postgresql+psycopg2://pca:pca@localhost:5432/pca
#
# Production (Supabase): Project Settings -> Database -> Connection string ->
# "URI". Use the pooler host for serverless-friendly connections, e.g.
# DATABASE_URL=postgresql+psycopg2://postgres.PROJECTREF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- ETL tuning -------------------------------------------------------------
PCA_BACKFILL_MONTHS=24
PCA_CHUNK_SIZE=250000

# --- Backend ----------------------------------------------------------------
# Comma-separated origins allowed to call the API (your deployed frontend URL).
CORS_ORIGINS=http://localhost:5173
